# warning-agent local runtime env template

# local artifact root
WARNING_AGENT_DATA_DIR=.warning-agent-data

# adapter-feishu notify-first bridge
# verified local adapter deployment endpoint
WARNING_AGENT_ADAPTER_FEISHU_BASE_URL=http://127.0.0.1:8787

# default Feishu delivery target for page_owner live bridge
# keep CHAT_ID as the default local target; if you prefer direct delivery to one user,
# clear CHAT_ID and set OPEN_ID instead.
WARNING_AGENT_ADAPTER_FEISHU_CHAT_ID=oc_c54c68a55fc363aa87c586da031a1292
WARNING_AGENT_ADAPTER_FEISHU_OPEN_ID=
WARNING_AGENT_ADAPTER_FEISHU_THREAD_ID=

# optional only when adapter-feishu enables provider webhook auth
WARNING_AGENT_ADAPTER_FEISHU_PROVIDER_WEBHOOK_AUTH_TOKEN=
