{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://warning-agent.local/schemas/incident-packet.v2.json",
  "title": "incident-packet.v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "candidate_source",
    "created_at",
    "environment",
    "service",
    "operation",
    "entity_type",
    "entity_key",
    "window",
    "prometheus",
    "signoz",
    "topology",
    "evidence_refs",
    "temporal_context"
  ],
  "properties": {
    "schema_version": {
      "const": "incident-packet.v2"
    },
    "packet_id": {
      "type": "string",
      "pattern": "^ipk_[a-z0-9_\\-]+$"
    },
    "candidate_source": {
      "enum": [
        "alertmanager_webhook",
        "prometheus_scan",
        "manual_replay",
        "signoz_alert"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "environment": {
      "type": "string",
      "minLength": 1
    },
    "service": {
      "type": "string",
      "minLength": 1
    },
    "operation": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "entity_type": {
      "enum": [
        "service",
        "service_operation"
      ]
    },
    "entity_key": {
      "type": "string",
      "minLength": 1
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_ts",
        "end_ts",
        "duration_sec"
      ],
      "properties": {
        "start_ts": {
          "type": "string",
          "format": "date-time"
        },
        "end_ts": {
          "type": "string",
          "format": "date-time"
        },
        "duration_sec": {
          "type": "integer",
          "minimum": 60,
          "maximum": 3600
        }
      }
    },
    "prometheus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alerts_firing",
        "error_rate",
        "error_rate_baseline",
        "error_rate_delta",
        "latency_p95_ms",
        "latency_p95_baseline_ms",
        "latency_p95_delta",
        "qps",
        "qps_baseline",
        "qps_delta",
        "saturation"
      ],
      "properties": {
        "alerts_firing": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "error_rate": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "error_rate_baseline": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "error_rate_delta": {
          "type": [
            "number",
            "null"
          ]
        },
        "latency_p95_ms": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "latency_p95_baseline_ms": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "latency_p95_delta": {
          "type": [
            "number",
            "null"
          ]
        },
        "qps": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "qps_baseline": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "qps_delta": {
          "type": [
            "number",
            "null"
          ]
        },
        "saturation": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "signoz": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "top_error_templates",
        "top_slow_operations",
        "trace_error_ratio",
        "sample_trace_ids",
        "sample_log_refs"
      ],
      "properties": {
        "top_error_templates": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "template_id",
              "template",
              "count",
              "novelty_score"
            ],
            "properties": {
              "template_id": {
                "type": "string",
                "minLength": 1
              },
              "template": {
                "type": "string",
                "minLength": 1
              },
              "count": {
                "type": "integer",
                "minimum": 1
              },
              "novelty_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        },
        "top_slow_operations": {
          "type": "array",
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "operation",
              "p95_ms",
              "error_ratio"
            ],
            "properties": {
              "operation": {
                "type": "string",
                "minLength": 1
              },
              "p95_ms": {
                "type": "number",
                "minimum": 0
              },
              "error_ratio": {
                "type": [
                  "number",
                  "null"
                ],
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        },
        "trace_error_ratio": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        },
        "sample_trace_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sample_log_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "alert_context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "rule_id",
            "source_url",
            "eval_window",
            "severity"
          ],
          "properties": {
            "rule_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "source_url": {
              "type": [
                "string",
                "null"
              ]
            },
            "eval_window": {
              "type": [
                "string",
                "null"
              ]
            },
            "severity": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "trace_detail_hints": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "trace_id",
              "span_name",
              "service_name",
              "target",
              "status_code"
            ],
            "properties": {
              "trace_id": {
                "type": "string",
                "minLength": 1
              },
              "span_name": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "service_name": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "target": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "status_code": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        }
      }
    },
    "topology": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tier",
        "owner",
        "repo_candidates",
        "upstream_count",
        "downstream_count",
        "blast_radius_score"
      ],
      "properties": {
        "tier": {
          "enum": [
            "tier0",
            "tier1",
            "tier2",
            "unknown"
          ]
        },
        "owner": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "repo_candidates": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "upstream_count": {
          "type": "integer",
          "minimum": 0
        },
        "downstream_count": {
          "type": "integer",
          "minimum": 0
        },
        "blast_radius_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "history": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recent_deploy": {
          "type": "boolean"
        },
        "similar_incident_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "similar_packet_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "evidence_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prometheus_query_refs",
        "signoz_query_refs"
      ],
      "properties": {
        "prometheus_query_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "signoz_query_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "temporal_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "error_rate_1h",
        "error_rate_24h",
        "error_rate_7d_p95",
        "latency_p95_1h",
        "latency_p95_24h",
        "qps_1h",
        "qps_24h",
        "anomaly_duration_sec",
        "deploy_age_sec",
        "rollback_recent",
        "new_error_template_ratio"
      ],
      "properties": {
        "error_rate_1h": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "error_rate_24h": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "error_rate_7d_p95": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "latency_p95_1h": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "latency_p95_24h": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "qps_1h": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "qps_24h": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "anomaly_duration_sec": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "deploy_age_sec": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "rollback_recent": {
          "type": "boolean"
        },
        "new_error_template_ratio": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
